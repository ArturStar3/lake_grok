{
  "version": 8,
  "name": "Basic (OSM-like)",
  "metadata": {
    "openmaptiles:version": "3.x"
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "mbtiles://{openmaptiles}"
    }
  },
  "glyphs": "{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2f2f2"
      }
    },
    {
      "id": "landcover-ice",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["in", "class", "ice"],
      "paint": {
        "fill-color": "#ffffff",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.95, 8, 0.85, 12, 0.7]
      }
    },
    {
      "id": "landcover-glacier",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "subclass", "glacier"],
      "paint": {
        "fill-color": "#ffffff",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.95, 8, 0.8, 12, 0.65]
      }
    },
    {
      "id": "landcover-farmland",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "minzoom": 5,
      "filter": ["in", "class", "farmland"],
      "paint": {
        "fill-color": "#eef0d8",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0, 7, 0.35, 10, 0.65, 14, 0.85]
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "minzoom": 5,
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#aedfa3",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0, 7, 0.25, 9, 0.55, 12, 0.75, 14, 0.85]
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "minzoom": 6,
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#cdebb0",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 6, 0, 8, 0.3, 10, 0.6, 14, 0.8]
      }
    },
    {
      "id": "landcover-sand",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "minzoom": 7,
      "filter": ["==", "class", "sand"],
      "paint": {
        "fill-color": "#f5e9c6",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 7, 0, 9, 0.4, 12, 0.75, 14, 0.9]
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "minzoom": 9,
      "filter": ["in", "class", "residential", "suburb", "neighbourhood"],
      "paint": {
        "fill-color": "#e0dfdf",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 9, 0, 11, 0.35, 14, 0.55]
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "minzoom": 7,
      "paint": {
        "fill-color": "#c8facc",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 7, 0, 9, 0.3, 11, 0.55, 14, 0.75]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", "intermittent", 1],
      "paint": {
        "fill-color": ["interpolate", ["linear"], ["zoom"], 0, "#d4dadc", 4, "#c8d4de", 7, "#aad3df", 12, "#aad3df"],
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.55, 5, 0.75, 8, 1]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 5,
      "filter": ["all", ["==", "class", "motorway"], ["!=", "ramp", 1]],
      "layout": {"line-cap": "round", "line-join": "round"},
      "paint": {
        "line-color": "#fc8",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0, 6, 0.6, 8, 1],
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.2, 8, 0.8, 12, 2.5]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 6,
      "filter": ["all", ["in", "class", "trunk", "primary", "secondary", "tertiary"], ["!=", "ramp", 1]],
      "layout": {"line-cap": "round", "line-join": "round"},
      "paint": {
        "line-color": "#fea",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 6, 0, 8, 0.7, 10, 1],
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.2, 10, 1, 14, 3]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 11,
      "filter": ["all", ["in", "class", "minor", "service", "track"]],
      "layout": {"line-cap": "round", "line-join": "round"},
      "paint": {
        "line-color": "#ffffff",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 11, 0, 12, 0.8, 14, 1],
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.3, 14, 2.5]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#d9d0c9",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0, 14, 0.7, 16, 0.9]
      }
    },
    {
      "id": "country-boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "minzoom": 1,
      "filter": ["all", ["==", "admin_level", 2], ["!=", "maritime", 1]],
      "layout": {"line-cap": "round", "line-join": "round"},
      "paint": {
        "line-color": "#9e9e9e",
        "line-width": ["interpolate", ["linear"], ["zoom"], 1, 0.6, 4, 1, 8, 1.5, 12, 2.5],
        "line-opacity": 0.85
      }
    },
    {
      "id": "place_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 14,
      "filter": ["all", ["==", "$type", "Point"], ["==", "class", "village"]],
      "layout": {
        "text-field": [
          "case",
          ["any",
            ["==", ["get", "name:ru"], "Нур-Султан"],
            ["==", ["get", "name:ru"], "Нур Султан"],
            ["==", ["get", "name"], "Nur-Sultan"],
            ["==", ["get", "name"], "Nur Sultan"],
            ["==", ["get", "name:en"], "Nur-Sultan"],
            ["==", ["get", "name:kk"], "Нұр-Сұлтан"],
            ["==", ["get", "name:latin"], "Nur-Sultan"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Нур-Султан"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Nur-Sultan"]
          ],
          "Астана",
          ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]]
        ],
        "text-font": ["Open Sans Regular"],
        "text-size": 10
      },
      "paint": {
        "text-color": "rgb(117, 129, 145)",
        "text-halo-color": "#f2f2f2",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 15,
      "filter": ["all", ["==", "$type", "Point"], ["==", "class", "town"]],
      "layout": {
        "text-field": [
          "case",
          ["any",
            ["==", ["get", "name:ru"], "Нур-Султан"],
            ["==", ["get", "name:ru"], "Нур Султан"],
            ["==", ["get", "name"], "Nur-Sultan"],
            ["==", ["get", "name"], "Nur Sultan"],
            ["==", ["get", "name:en"], "Nur-Sultan"],
            ["==", ["get", "name:kk"], "Нұр-Сұлтан"],
            ["==", ["get", "name:latin"], "Nur-Sultan"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Нур-Султан"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Nur-Sultan"]
          ],
          "Астана",
          ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]]
        ],
        "text-font": ["Open Sans Regular"],
        "text-size": 10
      },
      "paint": {
        "text-color": "rgb(117, 129, 145)",
        "text-halo-color": "#f2f2f2",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 14,
      "filter": ["all", ["==", "$type", "Point"], ["==", "class", "city"]],
      "layout": {
        "text-field": [
          "case",
          ["any",
            ["==", ["get", "name:ru"], "Нур-Султан"],
            ["==", ["get", "name:ru"], "Нур Султан"],
            ["==", ["get", "name"], "Nur-Sultan"],
            ["==", ["get", "name"], "Nur Sultan"],
            ["==", ["get", "name:en"], "Nur-Sultan"],
            ["==", ["get", "name:kk"], "Нұр-Сұлтан"],
            ["==", ["get", "name:latin"], "Nur-Sultan"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Нур-Султан"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Nur-Sultan"]
          ],
          "Астана",
          ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]]
        ],
        "text-font": ["Open Sans Regular"],
        "text-size": 12
      },
      "paint": {
        "text-color": "rgb(80, 95, 110)",
        "text-halo-color": "#f2f2f2",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_country",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 8,
      "filter": ["all", ["==", "$type", "Point"], ["==", "class", "country"]],
      "layout": {
        "text-field": [
          "case",
          ["any",
            ["==", ["get", "name:ru"], "Нур-Султан"],
            ["==", ["get", "name:ru"], "Нур Султан"],
            ["==", ["get", "name"], "Nur-Sultan"],
            ["==", ["get", "name"], "Nur Sultan"],
            ["==", ["get", "name:en"], "Nur-Sultan"],
            ["==", ["get", "name:kk"], "Нұр-Сұлтан"],
            ["==", ["get", "name:latin"], "Nur-Sultan"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Нур-Султан"],
            ["==", ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]], "Nur-Sultan"]
          ],
          "Астана",
          ["coalesce", ["get", "name:ru"], ["get", "name"], ["get", "name:latin"]]
        ],
        "text-font": ["Open Sans Regular"],
        "text-size": { "base": 1, "stops": [[0, 10], [6, 12]] },
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "rgb(153, 153, 153)",
        "text-halo-color": "rgba(242,242,242,0.85)",
        "text-halo-width": 1.4
      }
    }
  ]
}