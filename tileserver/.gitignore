# ============================================
# tileserver/ - TileServer GL (offline vector maps)
# The entire useful content of tileserver/ is published in git.
# The ONLY exceptions are the huge tile data files (*.mbtiles).
# ============================================

# --- Large tile data (NEVER commit - tens of GB) ---
*.mbtiles
terrain.mbtiles

# --- Downloaded archives and temp data from scripts ---
test_data.zip
*.zip

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*~
*.swp

# --- Artifacts from download commands (cleanup leftovers) ---
curl.exe
$null
-L
-o

# --- docker-compose.yml lives at project root only ---
docker-compose.yml

# Everything else in this folder is committed on purpose:
# - fonts/ (Open Sans .pbf glyphs)
# - styles/ (borders-labels.json, basic.json, etc.)
# - scripts/ (*.ps1, *.js)
# - config.json
# - data/name-overrides.json
# - sprites/ (if any)
# - .gitignore (this file)

# Safety negations in case broader ignores are added later
!fonts/
!styles/
!scripts/
!data/
!data/name-overrides.json
